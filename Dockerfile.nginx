FROM nginx:stable-alpine

# Bake the nginx config into the image (avoids Portainer file-mount errors)
COPY nginx/default.conf /etc/nginx/conf.d/default.conf

# Bake the public/ directory into the image too.
# This means nginx NEVER needs a volume mount to serve static files or
# locate index.php — it always has a copy from the build.
# Portainer rebuilds this image on every git deploy, so it stays current.
COPY public/ /Sites/byabsayee/public/