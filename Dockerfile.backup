FROM alpine:3.19

RUN apk add --no-cache mariadb-client tzdata

RUN echo '#!/bin/sh' > /usr/local/bin/run-backup.sh && \
    echo 'if mariadb-admin --defaults-file=/root/.my.cnf ping > /dev/null 2>&1; then' >> /usr/local/bin/run-backup.sh && \
    echo '    mariadb-dump --defaults-file=/root/.my.cnf "$DB_NAME" | gzip > /backup/"$DB_NAME"-$(date +%Y-%m-%d_%H-%M).sql.gz' >> /usr/local/bin/run-backup.sh && \
    echo '    find /backup -type f -name "$DB_NAME-*.sql.gz" -mtime +30 -delete' >> /usr/local/bin/run-backup.sh && \
    echo '    echo "Backup successful: $(date)"' >> /usr/local/bin/run-backup.sh && \
    echo 'else' >> /usr/local/bin/run-backup.sh && \
    echo '    echo "ERROR: Database connection failed. Please check your .env credentials." >&2' >> /usr/local/bin/run-backup.sh && \
    echo 'fi' >> /usr/local/bin/run-backup.sh

RUN chmod +x /usr/local/bin/run-backup.sh

ENTRYPOINT ["/bin/sh", "-c", "echo '[client]\nhost=${DB_HOST}\nuser=${DB_USER}\npassword=\"${DB_PASS}\"' > /root/.my.cnf && chmod 600 /root/.my.cnf && echo \"Running initial test backup...\" && /usr/local/bin/run-backup.sh && echo \"0 2 * * * /usr/local/bin/run-backup.sh\" > /etc/crontabs/root && exec crond -f -l 2"]